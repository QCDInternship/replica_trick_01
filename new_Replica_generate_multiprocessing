"""
Entanglement entropy in SU(3) lattice QCD via the Replica Lattice Method

Author: Lukas Wystemp - University of Manchester - Yr3 Physics Summer Project 2025

For values of alpha [0 - 1] creates a set of replica lattices and analyses the 
Wilson action evolution across configurations and <S_L+1 - S_L> for each alpha.
Specify run_number (folder name). 
Only supports action 'W' (Wilson action) with replica boundary conditions for now.
"""

import numpy as np
import os
import gauge_latticeqcd as glqcd
import lattice_collection as lc
import matplotlib.pyplot as plt
from multiprocessing import Process, Pool
from collections import defaultdict
from scipy import integrate
import time

action = 'W'
Nt, Nx, Ny, Nz = 16, 16, 16, 16
beta = 5.7
Nstart = 0
Nend = 1000
Ncfg = Nend - Nstart + 1
Nhits = 10
n = 2
s = 2
u0 = 1.
Nstart_analyze = 0
run_number = 1
alphas = [0, 0.2, 0.4, 0.6, 0.8, 1]
ensembles = [0, 1]
VERBOSE_ANALYSIS = True

def trace(msg):
    if VERBOSE_ANALYSIS:
        print(msg)

def create_base():
    base_dir = f"RunReplica{run_number}"
    if not os.path.exists(base_dir):
        os.mkdir(base_dir)
        print(f"Created directory: {base_dir}")
    else:
        print(f"Directory exists: {base_dir}")
    new_base_dir = f"Replica_{action}_{Nt}x{Nx}x{Ny}x{Nz}_b{int(beta * 100)}"
    new_base_dir = os.path.join(base_dir, new_base_dir)
    return new_base_dir

def run_replica_simulation(new_base_dir, alpha, ensemble):
    import os
    import gauge_latticeqcd as glqcd
    dir_name = new_base_dir + f"_alpha{alpha}_ensemble{ensemble}"
    filename_U1 = os.path.join(dir_name, f"config_{Nstart:01d}_U1.npy")
    if os.path.exists(filename_U1):
        U1 = np.load(filename_U1)
        print(f"Loading config {Nstart:01d}...")
    else:
        U1 = None
        print(f"Generating config {Nstart:01d}...")
    U = glqcd.ReplicaLattice(Nt, Nx, Ny, Nz, beta, u0, n, s, U1)
    matrices = glqcd.create_su3_set()
    U.markov_chain_sweep_replica(Ncfg, matrices, Nhits, dir_name, alpha, Nstart)

def main_control_run(new_base_dir):
    processes = []
    for alpha in alphas:
        for ensemble in ensembles:
            p = Process(target=run_replica_simulation, args=(new_base_dir, alpha, ensemble))
            p.start()
            processes.append(p)
    print("All processes started, waiting for completion...")
    for p in processes:
        p.join()
    print("All processes completed.")

def process_alpha_ensemble(new_base_dir, cfg_start, cfg_end, alpha, ensemble):
    import lattice_collection as lc
    import gauge_latticeqcd as glqcd
    dir_name = f"{new_base_dir}_alpha{alpha}_ensemble{ensemble}"
    trace(f"[plot] Load alpha={alpha}, ensemble={ensemble}, cfg=[{cfg_start},{cfg_end})")
    collection_1 = lc.fn_replica_lattice_collection(Nt, Nx, Ny, Nz, beta, start=cfg_start, end=cfg_end, path=dir_name)
    action_1 = []
    action_2 = []
    int_actions = []
    xcutoff_1 = Nx - s
    xcutoff_2 = Nx - (s + 1)
    for cfg in range(cfg_end - cfg_start):
        U1 = np.array(collection_1[cfg], dtype=np.complex128)
        lattice = glqcd.ReplicaLattice(Nt, Nx, Ny, Nz, beta, u0, n, s, U1=U1)
        S1 = lattice.calc_action_replica(xcutoff_1)
        S2 = lattice.calc_action_replica(xcutoff_2)
        action_1.append(S1)
        action_2.append(S2)
        S_int = lattice.calc_S_int(alpha, xcutoff_1, xcutoff_2)
        int_actions.append(S_int)
    trace(f"[plot] Done alpha={alpha}, ensemble={ensemble}")
    return alpha, ensemble, action_1, action_2, int_actions

def _plot_worker(args):
    return process_alpha_ensemble(*args)

def plot_actions(new_base_dir):
    trace("[plot] Build jobs")
    jobs = []
    for alpha in alphas:
        for ensemble in ensembles:
            jobs.append((new_base_dir, 0, Nend, alpha, ensemble))
    trace(f"[plot] Dispatch {len(jobs)} jobs")
    results = []
    with Pool() as pool:
        total = len(jobs)
        start = time.time()
        for i, res in enumerate(pool.imap_unordered(_plot_worker, jobs), 1):
            results.append(res)
            elapsed = time.time() - start
            rate = i / elapsed if elapsed > 0 else 0.0
            rem = total - i
            eta = rem / rate if rate > 0 else float('inf')
            trace(f"[plot][progress] {i}/{total} | elapsed={elapsed:.1f}s | ETA={eta:.1f}s")
    trace("[plot] Render")
    for alpha, ensemble, actions_1, actions_2, S_int in results:
        idx_range = range(0, Nend)
        color_base = {
            0.0: 'white',
            0.1: 'yellow',
            0.2: 'lime',
            0.4: 'green',
            0.5: 'pink',
            0.6: 'blue',
            0.7: 'purple',
            0.8: 'red',
            0.9: 'grey',
            1.0: 'black'
        }
        color = color_base[alpha]
        plt.plot(idx_range, actions_1, marker='o', label=fr'$S_L$, $\alpha={alpha}$, e={ensemble}', color=color)
        plt.plot(idx_range, actions_2, marker='x', label=fr'$S_{{L+\Delta L}}$, $\alpha={alpha}$, e={ensemble}', color=color)
        plt.plot(idx_range, S_int, marker='^', label=fr'$S_{{\text{{int}}}}$, $\alpha={alpha}$, e={ensemble}', color=color, linestyle='--')
    plt.xlabel('Configuration index')
    plt.ylabel('Wilson action S')
    plt.title('Wilson action across configurations')
    plt.grid(True)
    plt.legend(loc='upper left', fontsize='xx-small')
    out = f'Wilson_action_{Nt}x{Nx}x{Ny}x{Nz}_b{int(beta * 100)}_alpha=0-0.4_e=0-1.png'
    plt.savefig(out, dpi=300)
    trace(f"[plot] Saved {out}")
    plt.show()

def compute_action_diff(cfg_start, cfg_end, dir, alpha, ensemble):
    import lattice_collection as lc
    import gauge_latticeqcd as glqcd
    dir_name = f"{dir}_alpha{alpha}_ensemble{ensemble}"
    trace(f"[diff] Begin alpha={alpha}, ensemble={ensemble}, cfg=[{cfg_start},{cfg_end})")
    collection_1 = lc.fn_replica_lattice_collection(Nt, Nx, Ny, Nz, beta, start=cfg_start, end=cfg_end, path=dir_name)
    trace(f"[diff] Loaded {len(collection_1)} configs for alpha={alpha}, ensemble={ensemble}")
    actions_1 = []
    actions_2 = []
    xcutoff_1 = Nx - s
    xcutoff_2 = Nx - (s + 1)
    for cfg in range(cfg_end - cfg_start):
        U1 = np.array(collection_1[cfg], dtype=np.complex128)
        lattice1 = glqcd.ReplicaLattice(Nt, Nx, Ny, Nz, beta, u0, n, s, U1=U1)
        SL = lattice1.calc_action_replica(xcutoff_1)
        SLp1 = lattice1.calc_action_replica(xcutoff_2)
        actions_1.append(SL)
        actions_2.append(SLp1)
    S_diffs = (np.array(actions_2) - np.array(actions_1)) / ((Nt / n) * Ny * Nz)
    trace(f"[diff] Done alpha={alpha}, ensemble={ensemble}")
    return alpha, S_diffs

def _diff_worker(args):
    return compute_action_diff(*args)
 
def analyse_action_differences(new_base_dir):
    trace("[analysis] Build action-diff jobs")
    jobs = [(Nstart_analyze, Nend, new_base_dir, alpha, e) for alpha in alphas for e in ensembles]
    alpha_to_diffs = defaultdict(list)
    trace(f"[analysis] Launch pool with {len(jobs)} jobs")
    results = []
    with Pool() as pool:
        total = len(jobs)
        start = time.time()
        for i, res in enumerate(pool.imap_unordered(_diff_worker, jobs), 1):
            results.append(res)
            elapsed = time.time() - start
            rate = i / elapsed if elapsed > 0 else 0.0
            rem = total - i
            eta = rem / rate if rate > 0 else float('inf')
            trace(f"[analysis][progress] {i}/{total} | elapsed={elapsed:.1f}s | ETA={eta:.1f}s")
    trace(f"[analysis] Aggregate {len(results)} results")
    for alpha, S_diff in results:
        alpha_to_diffs[alpha].append(S_diff)
    S_alpha_diffs = []
    S_alpha_std = []
    trace("[analysis] Mean/std per alpha")
    for alpha in alphas:
        diffs = alpha_to_diffs[alpha]
        all_diffs = np.concatenate(diffs)
        mean_diff = np.mean(all_diffs)
        std = np.std(all_diffs)
        print(f"Alpha {alpha}: ⟨S_L+1 - S_L⟩ = {mean_diff} ± {std}")
        S_alpha_diffs.append(mean_diff)
        S_alpha_std.append(std)
    trace("[analysis] Plot ⟨S_L+1 - S_L⟩ vs α")
    plt.figure(figsize=(10, 6))
    plt.errorbar(alphas, S_alpha_diffs, yerr=S_alpha_std, marker='o')
    plt.ylabel(r'$\langle S_{L+1} - S_{L} \rangle$')
    plt.xlabel(r'$\alpha$')
    plt.title('Average Action Difference vs Alpha')
    plt.grid()
    c, l = c_func(S_alpha_diffs)
    plt.text(0.05, 0.1, f"Run number: {run_number}\n$N_t x N_s^3 = {Nt}x{Nx}^3$\nEnsembles: {ensembles[0]}-{ensembles[-1]}\nC({l:.2f}) fm = {c:.5f}", transform=plt.gca().transAxes, fontsize=10, bbox=dict(boxstyle='round', fc='blanchedalmond', ec='orange', alpha=0.5))
    out = f"action_diff_vs_alpha_W_{run_number}_{Nt}x{Nx}x{Ny}x{Nz}_alpha{alphas[0]}-{alphas[-1]}_e{ensembles[0]}-{ensembles[-1]}.png"
    plt.savefig(out, dpi=300)
    trace(f"[analysis] Saved {out}")
    plt.show()
    return S_alpha_diffs

def integrate_action_diffs(S_alpha_diffs, max_alpha=1):
    cut = np.array([(a, d) for a, d in zip(alphas, S_alpha_diffs) if a <= max_alpha])
    xs = cut[:, 0]
    ys = cut[:, 1]
    trace(f"[integrate] Nodes={xs.tolist()}")
    trace(f"[integrate] Values={ys.tolist()}")
    val = integrate.simpson(y=ys, x=xs)
    trace(f"[integrate] Simpson={val}")
    return val

def sommer_scale():
    r0 = 0.5
    tmp = -1.6805 - 1.7139 * (beta - 6.) + 0.8155 * (beta - 6.)**2 - 0.6667 * (beta - 6.)**3
    a = r0 * np.exp(tmp)
    trace(f"[sommer] beta={beta}, a={a} fm")
    return a

def c_func(S_alpha_diffs):
    integrated_diff = integrate_action_diffs(S_alpha_diffs)
    print(f"Integrated action difference: {integrated_diff}")
    a = sommer_scale()
    print(f"Sommer scale a = {a:.4f} fm")
    l = (s + 0.5) * a
    print(f"l = {l:.4f} fm")
    C = s**3 * integrated_diff
    print(f"C = {C}")
    return C, l

def main():
    new_base_dir = create_base()
    main_control_run(new_base_dir)
    trace("[main] Starting analysis after sweeps are collected")
    S_alpha_diffs = analyse_action_differences(new_base_dir)
    c, l = c_func(S_alpha_diffs)
    print(f"C({l:.2f} fm) = {c:.8f}")

if __name__ == "__main__":
    main()
